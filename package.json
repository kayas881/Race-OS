{
  "name": "race-os-financial-hub",
  "version": "1.0.0",
  "description": "Financial Hub for Race-OS - Complete tax management and transaction tracking",
  "scripts": {
    "dev": "npm run backend & npm run frontend",
    "start": "npm run dev",
    "backend": "cd financial-hub/backend && npm start",
    "frontend": "cd financial-hub/frontend && npm start",
    "install-all": "npm run install-backend && npm run install-frontend",
    "install-backend": "cd financial-hub/backend && npm install",
    "install-frontend": "cd financial-hub/frontend && npm install",
    "build": "cd financial-hub/frontend && npm run build",
    "test": "cd financial-hub/backend && npm test",
    "clean": "npm run clean-backend && npm run clean-frontend",
    "clean-backend": "cd financial-hub/backend && rm -rf node_modules",
    "clean-frontend": "cd financial-hub/frontend && rm -rf node_modules",
    "quick": "scripts\\start-dev.bat",
    "ps": "powershell -ExecutionPolicy Bypass -File scripts\\quick-start.ps1"
  },
  "keywords": [
    "financial",
    "tax",
    "transactions",
    "dashboard",
    "mongodb",
    "react",
    "nodejs"
  ],
  "author": "Race-OS Team",
  "license": "MIT"
}
