# Frontend Environment Configuration Example
# Copy this file to .env.local and fill in your actual values

# Appwrite Configuration
REACT_APP_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
REACT_APP_APPWRITE_PROJECT_ID=your_project_id_here
REACT_APP_APPWRITE_PROJECT_NAME=your_project_name
REACT_APP_APPWRITE_DATABASE_ID=race-os-financial-hub
REACT_APP_APPWRITE_USERS_COLLECTION_ID=users

# API Configuration
REACT_APP_API_URL=http://localhost:5000